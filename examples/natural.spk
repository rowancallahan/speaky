as an aside Natural sentence-form examples

let x be 5
let name be string literal Alice
let greeting be enchant with string hello variable name

open if x is greater than 3
    print with string literal big
close if

open if x is equal to 5
    print with string literal five
close if

open if x is not equal to 0
    print with string literal nonzero
close if

increase x by 1
decrease x by 2
multiply x by 3
divide x by 4

let result be enchant with math A mat mul B
